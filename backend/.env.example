# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database - PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=academic_platform
PG_USER=postgres
PG_PASSWORD=your_secure_password

# Database - MongoDB (for chat/logs)
MONGO_URI=mongodb://localhost:27017/academic_chat

# Redis (for sessions/queues)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET=your_super_secure_jwt_secret_key_min_64_chars
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret
JWT_REFRESH_EXPIRE=30d

# Multi-Factor Authentication
MFA_ISSUER=AcademicResearchPlatform

# AWS S3 Storage
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=academic-platform-files

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@academicplatform.com
EMAIL_FROM_NAME=Academic Research Platform

# SMS - Twilio
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE=+1234567890

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your_firebase_project
FIREBASE_CLIENT_EMAIL=your_firebase_email
FIREBASE_PRIVATE_KEY=your_firebase_key

# OpenAI
OPENAI_API_KEY=sk-your_openai_key
OPENAI_MODEL=gpt-4-turbo-preview

# Google Gemini AI
GEMINI_API_KEY=your_gemini_key

# Video Conferencing
JITSI_SERVER=meet.jit.si
ZOOM_API_KEY=your_zoom_key
ZOOM_API_SECRET=your_zoom_secret

# Stripe (Payments for SaaS)
STRIPE_SECRET_KEY=sk_live_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Frontend URL
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# File Upload
MAX_FILE_SIZE=104857600
ALLOWED_FILE_TYPES=pdf,doc,docx,ppt,pptx,xls,xlsx,zip,jpg,jpeg,png,gif,mp4,mp3,wav
